{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "technology_generations.schema.json",
  "title": "Technology Generations",
  "description": "Major technology eras (pure mechanical, electromechanical, solid state)",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
      "title": { "type": "string", "minLength": 1 },
      "display_order": { "type": "integer", "minimum": 0 },
      "description": { "type": "string" },
      "technology_generation": {
        "type": "string",
        "description": "Short code (PM, EM, SS)"
      }
    },
    "required": ["slug", "title", "display_order", "description", "technology_generation"],
    "additionalProperties": false
  }
}
