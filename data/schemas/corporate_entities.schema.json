{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "corporate_entities.schema.json",
  "title": "Corporate Entities",
  "description": "Specific companies and divisions with operational dates, linked to manufacturer brands",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "name": { "type": "string", "minLength": 1 },
      "manufacturer_slug": {
        "type": "string",
        "description": "References a slug in manufacturers.json"
      },
      "year_start": { "type": ["integer", "null"], "minimum": 1800 },
      "year_end": { "type": ["integer", "null"], "minimum": 1800 },
      "headquarters_city": { "type": "string" },
      "headquarters_state": { "type": "string" },
      "headquarters_country": { "type": "string" }
    },
    "required": ["name", "manufacturer_slug"],
    "additionalProperties": false
  }
}
