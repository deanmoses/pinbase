{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "display_types.schema.json",
  "title": "Display Types",
  "description": "High-level display technology categories (reels, alphanumeric, DMD, LCD, etc.)",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "display_type": { "type": "string", "minLength": 1 },
      "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
      "title": { "type": "string", "minLength": 1 },
      "display_order": { "type": "integer", "minimum": 0 },
      "description": { "type": "string" }
    },
    "required": ["display_type", "slug", "title", "display_order", "description"],
    "additionalProperties": false
  }
}
