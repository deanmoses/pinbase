{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "technology_subgenerations.schema.json",
  "title": "Technology Subgenerations",
  "description": "Subdivisions within a technology generation (discrete, integrated, PC-based)",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
      "name": { "type": "string", "minLength": 1 },
      "display_order": { "type": "integer", "minimum": 0 },
      "description": { "type": "string" },
      "technology_generation_slug": {
        "type": "string",
        "description": "References a slug in technology_generations.json"
      }
    },
    "required": ["slug", "name", "display_order", "description", "technology_generation_slug"],
    "additionalProperties": false
  }
}
