{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "credits.schema.json",
  "title": "Credits",
  "description": "Assignments of people to roles on series",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "series_slug": {
        "type": "string",
        "description": "References a slug in series.json"
      },
      "person_slug": {
        "type": "string",
        "description": "References a slug in people.json"
      },
      "role": {
        "type": "string",
        "description": "Role name matching a name in credit_roles.json"
      }
    },
    "required": ["series_slug", "person_slug", "role"],
    "additionalProperties": false
  }
}
