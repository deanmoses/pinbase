{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "systems.schema.json",
  "title": "Systems",
  "description": "MPU/platform systems used in pinball machines",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
      "name": { "type": "string", "minLength": 1 },
      "description": { "type": "string" },
      "manufacturer_slug": {
        "type": "string",
        "description": "References a slug in manufacturers.json"
      },
      "mpu_strings": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 },
        "description": "Alternative names used for IPDB ingestion mapping"
      }
    },
    "required": ["slug", "name"],
    "additionalProperties": false
  }
}
