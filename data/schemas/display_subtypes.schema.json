{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "display_subtypes.schema.json",
  "title": "Display Subtypes",
  "description": "Specific display technologies within a display type (nixie tube, 7-segment, plasma DMD, etc.)",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
      "name": { "type": "string", "minLength": 1 },
      "display_order": { "type": "integer", "minimum": 0 },
      "description": { "type": "string" },
      "display_type_slug": {
        "type": "string",
        "description": "References a slug in display_types.json"
      }
    },
    "required": ["slug", "name", "display_order", "description", "display_type_slug"],
    "additionalProperties": false
  }
}
