{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "manufacturers.schema.json",
  "title": "Manufacturers",
  "description": "Pinball manufacturer brands (Bally, Williams, Stern, etc.)",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
      "name": { "type": "string", "minLength": 1 },
      "description": { "type": "string" }
    },
    "required": ["slug", "name"],
    "additionalProperties": false
  }
}
