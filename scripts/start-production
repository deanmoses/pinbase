#!/usr/bin/env sh
set -eu
cd "$(dirname "$0")/.."

PORT="${PORT:-8080}"
NODE_PORT="${NODE_PORT:-3000}"
DJANGO_PORT="${DJANGO_PORT:-8000}"

# Mirror Railway's commit SHA into the PUBLIC_ namespace at runtime so
# `$env/dynamic/public` in hooks.client.ts resolves to a real release tag
# in the browser. vite.config.ts does the same mirror at build time for
# sourcemap upload, but that only affects the build container's process —
# the Node SSR process launched below is a separate invocation that needs
# its own mirror. Without this, browser events ship with no release tag
# and Sentry can't match them to uploaded sourcemaps.
#
# Only mirror if there's a real value to mirror. Falling through to an
# empty string would stamp Sentry events with release="" instead of
# letting the SDK omit the field — same silent sourcemap-mismatch
# failure mode this mirror exists to prevent. In production the
# core.E207 preflight blocks the deploy if RAILWAY_GIT_COMMIT_SHA is
# unset, so this guard only matters when the script runs outside Railway.
if [ -n "${PUBLIC_RAILWAY_GIT_COMMIT_SHA:-${RAILWAY_GIT_COMMIT_SHA:-}}" ]; then
	export PUBLIC_RAILWAY_GIT_COMMIT_SHA="${PUBLIC_RAILWAY_GIT_COMMIT_SHA:-${RAILWAY_GIT_COMMIT_SHA}}"
fi

cleanup() {
	kill "${CADDY_PID:-0}" "${NODE_PID:-0}" "${DJANGO_PID:-0}" 2>/dev/null || true
}

trap cleanup EXIT INT TERM

.venv/bin/gunicorn config.wsgi:application --bind 127.0.0.1:"${DJANGO_PORT}" --workers 2 --timeout 60 --graceful-timeout 30 &
DJANGO_PID=$!

cd frontend_runtime
HOST=127.0.0.1 PORT="${NODE_PORT}" node build/index.js &
NODE_PID=$!
cd ..

PORT="${PORT}" NODE_PORT="${NODE_PORT}" DJANGO_PORT="${DJANGO_PORT}" \
	caddy run --config /app/Caddyfile --adapter caddyfile &
CADDY_PID=$!

while kill -0 "${CADDY_PID}" 2>/dev/null && \
	kill -0 "${NODE_PID}" 2>/dev/null && \
	kill -0 "${DJANGO_PID}" 2>/dev/null; do
	sleep 1
done

STATUS=1
for pid in "${CADDY_PID}" "${NODE_PID}" "${DJANGO_PID}"; do
	if ! kill -0 "${pid}" 2>/dev/null; then
		wait "${pid}" || STATUS=$?
		break
	fi
done

cleanup
wait || true
exit "${STATUS}"
